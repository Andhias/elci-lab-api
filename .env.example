APP_NAME=Elevator Escalator AI API
ENV=development
API_V1_PREFIX=/api/v1
DATABASE_URL=sqlite:///C:/Users/Andhias/services/api/local_dev.db

# ── LLM Provider Selection ───────────────────────────────────────────────────
# Options: openai | anthropic | gemini | openai_compatible
LLM_PROVIDER=openai

# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Google Gemini ──────────────────────────────────────────────────────────
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-2.0-flash

# ── OpenAI-Compatible (Ollama, LM Studio, etc.) ───────────────────────────
OPENAI_COMPATIBLE_BASE_URL=http://localhost:11434/v1
OPENAI_COMPATIBLE_API_KEY=ollama
OPENAI_COMPATIBLE_MODEL=llama3
